{
  "version": 2,
  "builds": [
    {
      "src": "api/vworld-proxy.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/[...path].js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "outputDirectory": "dist"
      }
    }
  ],
  "routes": [
    { "src": "/api/vworld-proxy", "dest": "/api/vworld-proxy.js" },
    { "src": "/api/(.*)", "dest": "/api/[...path].js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
