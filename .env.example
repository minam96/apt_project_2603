# 공공데이터포털 (data.go.kr) API 키 (Decoding 키)
# https://www.data.go.kr/ 에서 발급
DATA_GO_KR_API_KEY=

# V-World API 키 (국토정보플랫폼)
# https://www.vworld.kr/dev/v4dv_2ddataguide2_s001.do 에서 발급
VWORLD_API_KEY=

# 법제처 Open API 인증코드 (선택)
# https://open.law.go.kr/ 에서 발급
LAW_API_OC=

# Optional separate VWorld 2D Data API key/domain for zoning lookup fallback
VWORLD_DATA_API_KEY=
# local dev example: localhost
VWORLD_DATA_DOMAIN=
