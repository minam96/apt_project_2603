# 공공데이터포털 (data.go.kr) API 키 (Decoding 키)
# https://www.data.go.kr/ 에서 발급
DATA_GO_KR_API_KEY=

# V-World API 키 (국토정보플랫폼)
# https://www.vworld.kr/dev/v4dv_2ddataguide2_s001.do 에서 발급
VWORLD_API_KEY=

# Optional separate VWorld data API key. If omitted, the app falls back to VWORLD_API_KEY.
VWORLD_DATA_API_KEY=

# VWorld land-use attribute API key used for detailed zoning lookup
VWORLD_API_KEY_getLandUse=

# Optional VWorld domain / referer value
VWORLD_DATA_DOMAIN=

# Optional VWorld proxy base used when the direct VWorld request times out
VWORLD_PROXY_BASE=

# Kakao Local REST API key used for runtime fallback geocoding
KAKAO_REST_API_KEY=

# Supabase cache used for zoning / apartment enrichment fallback
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Build-cache route protection. Keep disabled unless you explicitly use the route.
CACHE_BUILD_ENABLED=
CACHE_TOKEN=

# Optional allowed origins for browser clients
ALLOWED_ORIGINS=

# Optional Seoul open data keys
DATA_SEOUL_realestate=
DATA_SEOUL_getLandUse=

# 법제처 Open API 인증코드 (선택)
# https://open.law.go.kr/ 에서 발급
LAW_API_OC=
